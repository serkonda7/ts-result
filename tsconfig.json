    "rootDir": ".",
    "target": "esnext",
    "module": "preserve",
    "moduleResolution": "bundler",
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true,
  },
  "include": [
    "src",
    "scripts",
  ],
}
