{
"compilerOptions": {
    "rootDir": ".",
    "target": "esnext",
    "module": "preserve",
    "moduleResolution": "bundler",
    "declaration": true,
    "emitDeclarationOnly": true, // TS to JS is handled by bun
    "outDir": "dist",
    "skipLibCheck": true,
    "strict": true
  },
  "include": [
    "src/result.ts",
  ],
}
