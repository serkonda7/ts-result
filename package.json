{
  "name": "@serkonda7/ts-result",
  "description": "Minimalistic Result type for TypeScript.",
  "version": "1.0.5",
  "license": "MIT",
  "author": "serkonda7",
  "homepage": "https://github.com/serkonda7/ts-result",
  "repository": {
    "type": "git",
    "url": "https://github.com/serkonda7/ts-result"
  },
  "bugs": {
    "url": "https://github.com/serkonda7/ts-result/issues"
  },
  "keywords": ["result", "typescript", "error-handling"],
  "type": "module",
  "main": "dist/result.js",
  "types": "dist/src/result.d.ts",
  "files": ["dist"],
  "scripts": {
    "lint": "biome check --write",
    "lint:ci": "biome ci",
    "check": "tsgo",
    "test": "bun test",
    "build": "tsgo -p tsconfig.build.json && bun run scripts/build.ts",
    "prepack": "bun run build",
    "pack": "bun pm pack --filename ts-result.tgz"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "bun@1.3.13",
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/bun": "~1.3.13",
    "@typescript/native-preview": "~7.0.0-dev.20260511.1"
  }
}
